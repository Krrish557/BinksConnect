# Server
PORT=5000
JWT_SECRET=change-this-to-a-random-secret

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_ALLOCATOR_STRATEGY=round_robin

# Sudo: Your Telegram user ID (get it from @userinfobot)
SUDO_USER_ID=
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Turso (SQLite-compatible cloud DB)
# Sign up at https://turso.tech, create a database, then set these:
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your-auth-token-here

# Optional: Add channels via API after bot setup
# POST /api/admin/channels { "channel_id": "-1001234567890", "title": "Storage-01" }

# Keep-alive: Set this to your Render backend URL to prevent idle spin-down
# The server will ping itself every 5 minutes
RENDER_URL=
PING_URL=